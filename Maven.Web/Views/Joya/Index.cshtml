@model List<Maven.Application.DTOs.JoyaDTO>

@{
    ViewData["Title"] = "Objetos Subastables";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Objetos Subastables</h2>

    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Crear objeto
        </a>

        @if (User.IsInRole("ADMIN"))
        {
            <a asp-action="Inactivos" class="btn btn-outline-secondary">
                <i class="bi bi-eye-slash me-1"></i> Inactivos
            </a>
        }
    </div>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No hay objetos registrados.</div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var j in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    @if (!string.IsNullOrWhiteSpace(j.ImagenPrincipal))
                    {
                        <img src="@j.ImagenPrincipal"
                             class="card-img-top"
                             style="height: 180px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center bg-light"
                             style="height: 180px;">
                            <span class="text-muted">(sin imagen)</span>
                        </div>
                    }

                    <div class="card-body">
                        <h5 class="card-title mb-2">@j.Nombre</h5>

                        @if (!string.IsNullOrWhiteSpace(j.CategoriasTexto))
                        {
                            <p class="mb-2">
                                <span class="badge bg-secondary">@j.CategoriasTexto</span>
                            </p>
                        }

                        <p class="mb-1">
                            <strong>Condición:</strong>
                            @(j.CondicionObjeto?.NombreCondicion ?? "-")
                        </p>
                        <p class="mb-0">
                            <strong>Estado:</strong>
                            @(j.EstadoObjeto?.NombreEstado ?? "-")
                        </p>
                    </div>

                    <div class="card-footer bg-white border-0 pt-0 pb-3 px-3">
                        <div class="d-flex justify-content-between gap-2">
                            @if (j.EstadoObjeto?.NombreEstado != "EN_SUBASTA")
                            {
                                <a class="btn btn-sm btn-outline-secondary"
                                   asp-action="Edit"
                                   asp-route-id="@j.JoyaId">
                                    Editar
                                </a>
                            }
                            <a class="btn btn-sm btn-outline-primary"
                               asp-action="Detalle"
                               asp-route-id="@j.JoyaId">
                                Ver detalle
                            </a>

                            <a class="btn btn-sm btn-outline-danger"
                               asp-action="Delete"
                               asp-route-id="@j.JoyaId">
                                Eliminar
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}