@model List<Maven.Application.DTOs.JoyaListDto>

@{
    ViewData["Title"] = "Objetos Subastables";
    var total = Model?.Count ?? 0;
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
    <div>
        <h1 class="h3 mb-1">Objetos Subastables</h1>
        <p class="text-muted mb-0">
            Explora el catálogo disponible. Total: <strong>@total</strong>.
        </p>
    </div>

    <div class="d-flex gap-2">
        @* Si después quieres exportar PDF, aquí lo agregas *@
        @*<a asp-controller="Joya" asp-action="ReportePDF" class="btn btn-outline-secondary">
            <i class="bi bi-filetype-pdf me-1"></i> Exportar PDF
        </a>*@
    </div>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info d-flex align-items-center" role="alert">
        <i class="bi bi-info-circle me-2"></i>
        <div>No hay objetos registrados.</div>
    </div>
}
else
{
    <section aria-label="Listado de objetos subastables">
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">

            @foreach (var j in Model)
            {
                <div class="col">
                    <article class="card h-100 shadow-sm border-0">
                        <!-- Imagen -->
                        <div class="rounded-top overflow-hidden bg-body-tertiary" style="height: 320px;">
                            @if (!string.IsNullOrWhiteSpace(j.ImagenPrincipal))
                            {
                                <img class="w-100 h-100 object-fit-cover rounded-top"
                                     src="@j.ImagenPrincipal"
                                     alt="Imagen del objeto @j.Nombre"
                                     loading="lazy" />
                            }
                            else
                            {
                                <div class="h-100 d-flex flex-column justify-content-center align-items-center text-muted">
                                    <i class="bi bi-image fs-1"></i>
                                    <span class="small">Sin imagen</span>
                                </div>
                            }
                        </div>

                        <!-- Contenido -->
                        <div class="card-body">
                            <h2 class="h6 fw-semibold mb-1 text-truncate" title="@j.Nombre">
                                @j.Nombre
                            </h2>

                            <div class="text-muted small mb-2">
                                <span class="me-2">
                                    <i class="bi bi-tags me-1"></i>
                                    @(!string.IsNullOrWhiteSpace(j.Categorias) ? j.Categorias : "Sin categorías")
                                </span>
                            </div>

                            <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
                                <span class="badge text-bg-light border">
                                    <i class="bi bi-shield-check me-1"></i>
                                    @(!string.IsNullOrWhiteSpace(j.Condicion) ? j.Condicion : "Sin condición")
                                </span>

                            </div>
                        </div>

                        <!-- Acciones -->
                        <div class="card-footer bg-body border-0 pt-0 pb-3">
                            <div class="d-grid gap-2 px-2">
                                <a class="btn btn-primary"
                                   asp-action="Detalle"
                                   asp-route-id="@j.JoyaId">
                                    <i class="bi bi-eye me-1"></i> Ver detalle
                                </a>
                            </div>
                        </div>
                    </article>
                </div>
            }

        </div>
    </section>
}

@section Scripts {
    <style>
        .card:hover {
            transform: translateY(-3px);
            transition: transform .18s ease;
        }
    </style>
}
