@model Maven.Application.DTOs.JoyaDTO

@{
    ViewData["Title"] = "Detalle de joya";

    var estadoNombre = Model.EstadoObjeto?.NombreEstado ?? "No disponible";
    var condicionNombre = Model.CondicionObjeto?.NombreCondicion ?? "No disponible";
    var vendedorNombre = Model.Vendedor?.NombreCompleto ?? "No disponible";

    var estadoUpper = estadoNombre.ToUpper();
    var claseEstado = estadoUpper.Contains("ACTIV") ? "text-bg-success"
                    : estadoUpper.Contains("INACT") ? "text-bg-danger"
                    : "text-bg-secondary";
}

<nav class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Inicio</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-controller="Joya" asp-action="Index" class="text-decoration-none">Joyas</a>
        </li>
        <li class="breadcrumb-item active">Detalle</li>
    </ol>
</nav>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
    <div>
        <h1 class="h3 mb-1">Detalle de joya</h1>
        <p class="text-muted mb-0">Información completa de la joya seleccionada.</p>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.JoyaId" class="btn btn-outline-primary">
            <i class="bi bi-pencil-square me-1"></i> Editar
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Volver
        </a>
    </div>
</div>

<article class="card shadow-sm border-0">
    <div class="card-body p-4">

        <header class="mb-4">
            <h2 class="h4 fw-semibold mb-2">@Model.Nombre</h2>

            <div class="d-flex flex-wrap gap-2">

                <span class="badge text-bg-light border">
                    <i class="bi bi-person me-1"></i>
                    @vendedorNombre
                </span>

                <span class="badge @claseEstado">
                    <i class="bi bi-shield-check me-1"></i>
                    @estadoNombre
                </span>

                <span class="badge text-bg-warning text-dark">
                    <i class="bi bi-star me-1"></i>
                    @condicionNombre
                </span>

            </div>
        </header>

        <section class="mb-4">
            <div class="row g-4">

                <div class="col-lg-6">

                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">

                            <h3 class="h5 mb-3">Imágenes del objeto</h3>

                            @if (Model.JoyaImagen != null && Model.JoyaImagen.Any())
                            {
                                <div class="row g-3">

                                    @foreach (var img in Model.JoyaImagen)
                                    {
                                        <div class="col-6 col-md-4">

                                            <div class="ratio ratio-1x1 border rounded overflow-hidden">

                                                <img src="@img.UrlImagen"
                                                     alt="@Model.Nombre"
                                                     class="w-100 h-100"
                                                     style="object-fit:cover; cursor:pointer;"
                                                     onclick="mostrarImagen('@img.UrlImagen')"
                                                     data-bs-toggle="modal"
                                                     data-bs-target="#modalImagen" />

                                            </div>

                                        </div>
                                    }

                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-0">
                                    Esta joya aún no tiene imágenes registradas.
                                </p>
                            }

                        </div>
                    </div>

                </div>

                <div class="col-lg-6">

                    <div class="card border-0 shadow-sm h-100">

                        <div class="card-body">

                            <div class="d-flex justify-content-between mb-3">

                                <h3 class="h5 mb-0">
                                    Detalle del objeto
                                </h3>

                                <span class="badge text-bg-light border">
                                    ID @Model.JoyaId
                                </span>

                            </div>

                            <ul class="list-group list-group-flush">

                                <li class="list-group-item d-flex justify-content-between">
                                    <strong>Nombre</strong>
                                    <span>@Model.Nombre</span>
                                </li>

                                <li class="list-group-item">
                                    <strong>Descripción completa</strong>
                                    <div class="text-muted mt-1">
                                        @Model.Descripcion
                                    </div>
                                </li>

                                <li class="list-group-item d-flex justify-content-between">
                                    <strong>Categorías asociadas</strong>

                                    @if (!string.IsNullOrWhiteSpace(Model.CategoriasTexto))
                                    {
                                        <span class="badge text-bg-secondary">
                                            @Model.CategoriasTexto
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">
                                            Sin categorías
                                        </span>
                                    }
                                </li>

                                <li class="list-group-item d-flex justify-content-between">
                                    <strong>Condición del objeto</strong>

                                    <span class="badge text-bg-warning text-dark">
                                        @condicionNombre
                                    </span>
                                </li>

                                <li class="list-group-item d-flex justify-content-between">
                                    <strong>Estado actual del objeto</strong>

                                    <span class="badge @claseEstado">
                                        @estadoNombre
                                    </span>
                                </li>

                                <li class="list-group-item d-flex justify-content-between">
                                    <strong>Fecha de registro</strong>

                                    <span>
                                        @Model.FechaRegistro.ToString("dd/MM/yyyy")
                                    </span>
                                </li>

                                <li class="list-group-item d-flex justify-content-between">
                                    <strong>Propietario del objeto</strong>

                                    <span>
                                        @vendedorNombre
                                    </span>
                                </li>

                            </ul>

                        </div>

                    </div>

                </div>

            </div>

        </section>

        <hr class="my-4" />

        <section class="mb-4">

            <h3 class="h5 mb-3">
                Subastas donde ha participado
            </h3>

            @if (Model.Subasta != null && Model.Subasta.Any())
            {

                <div class="table-responsive">

                    <table class="table table-striped align-middle">

                        <thead class="table-light">

                            <tr>

                                <th>Identificador de la subasta</th>

                                <th>Fecha de inicio</th>

                                <th>Fecha de cierre</th>

                                <th>Estado de la subasta</th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var s in Model.Subasta.OrderByDescending(x => x.FechaInicio))
                            {

                                <tr>

                                    <td>@s.SubastaId</td>

                                    <td>@s.FechaInicio.ToString("dd/MM/yyyy")</td>

                                    <td>@s.FechaCierre.ToString("dd/MM/yyyy")</td>

                                    <td>
                                        @(s.EstadoSubasta?.NombreEstado ?? "-")
                                    </td>

                                </tr>

                            }

                        </tbody>

                    </table>

                </div>

            }
            else
            {

                <p class="text-muted">
                    Esta joya todavía no ha participado en ninguna subasta.
                </p>

            }

        </section>

        <hr class="my-4" />

        <div class="d-flex justify-content-end gap-2">

            <a asp-action="Delete" asp-route-id="@Model.JoyaId"
               class="btn btn-outline-danger">

                <i class="bi bi-trash me-1"></i>
                Eliminar

            </a>

            <a asp-action="Index"
               class="btn btn-outline-secondary">

                <i class="bi bi-arrow-left me-1"></i>
                Regresar al listado

            </a>

        </div>

    </div>
</article>

<div class="modal fade" id="modalImagen" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content bg-dark border-0">

            <div class="modal-body text-center p-0">

                <img id="imagenGrande"
                     src=""
                     class="img-fluid"
                     style="max-height:90vh;" />

            </div>

        </div>
    </div>
</div>

<script>
    function mostrarImagen(url){
    document.getElementById("imagenGrande").src = url;
    }
</script>