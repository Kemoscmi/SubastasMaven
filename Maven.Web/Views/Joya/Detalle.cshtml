@model Maven.Application.DTOs.JoyaDTO

@{
    ViewData["Title"] = "Detalle de joya";

    var estadoNombre = Model.EstadoObjeto?.NombreEstado ?? "No disponible";
    var condicionNombre = Model.CondicionObjeto?.NombreCondicion ?? "No disponible";
    var vendedorNombre = Model.Vendedor?.NombreCompleto ?? "No disponible";

    var estadoUpper = estadoNombre.ToUpper();
    var claseEstado = estadoUpper.Contains("ACTIV") ? "text-bg-success"
                    : estadoUpper.Contains("INACT") ? "text-bg-danger"
                    : "text-bg-secondary";
}

<nav class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Inicio</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-controller="Joya" asp-action="Index" class="text-decoration-none">Joyas</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Detalle</li>
    </ol>
</nav>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
    <div>
        <h1 class="h3 mb-1">Detalle de joya</h1>
        <p class="text-muted mb-0">Información completa de la joya seleccionada.</p>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.JoyaId" class="btn btn-outline-primary">
            <i class="bi bi-pencil-square me-1"></i> Editar
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Volver
        </a>
    </div>
</div>
<article class="card shadow-sm border-0">
    <div class="card-body p-4">

        <!-- Encabezado básico -->
        <header class="mb-3">
            <h2 class="h4 fw-semibold mb-1">@Model.Nombre</h2>

            <div class="d-flex flex-wrap gap-2 align-items-center">
                <span class="badge text-bg-light border">
                    <i class="bi bi-person me-1"></i>
                    @vendedorNombre
                </span>

                <span class="badge @claseEstado">
                    <i class="bi bi-shield-check me-1"></i>
                    @estadoNombre
                </span>

                <span class="badge text-bg-warning text-dark">
                    <i class="bi bi-star me-1"></i>
                    @condicionNombre
                </span>
            </div>
        </header>

        <hr class="my-3" />

        <!--  TODAS las imágenes de la joya -->
        <section class="mb-4">
            <h3 class="h5 mb-3">Imágenes de la joya</h3>

            @if (Model.JoyaImagen != null && Model.JoyaImagen.Any())
            {
                <div class="row g-3">
                    @foreach (var img in Model.JoyaImagen)
                    {
                        <div class="col-6 col-md-3">
                            <div class="ratio ratio-1x1 border rounded overflow-hidden">
                                <img src="@img.UrlImagen"
                                     alt="@Model.Nombre"
                                     class="w-100 h-100"
                                     style="object-fit: cover;" />
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted mb-0">(Esta joya aún no tiene imágenes registradas.)</p>
            }
        </section>

        <hr class="my-3" />

        <!--  Información descriptiva + CATEGORÍAS -->
        <section class="mb-4">
            <h3 class="h5 mb-3">Información de la joya</h3>

            <dl class="row mb-0">
                <dt class="col-12 col-md-4 text-muted">ID Joya</dt>
                <dd class="col-12 col-md-8">
                    <span class="badge text-bg-light border">@Model.JoyaId</span>
                </dd>

                <dt class="col-12 col-md-4 text-muted">Descripción</dt>
                <dd class="col-12 col-md-8">
                    @Model.Descripcion
                </dd>

                <dt class="col-12 col-md-4 text-muted">Fecha de registro</dt>
                <dd class="col-12 col-md-8">
                    @Model.FechaRegistro.ToString("dd/MM/yyyy")
                </dd>

                <dt class="col-12 col-md-4 text-muted">Categorías</dt>
                <dd class="col-12 col-md-8">
                    @if (!string.IsNullOrWhiteSpace(Model.CategoriasTexto))
                    {
                        <span class="badge text-bg-secondary">@Model.CategoriasTexto</span>
                    }
                    else
                    {
                        <span class="text-muted">Sin categorías asociadas.</span>
                    }
                </dd>
            </dl>
        </section>

        <hr class="my-3" />

       
        <section class="mb-4">
            <h3 class="h5 mb-3">Historial de subastas de esta joya</h3>

            @if (Model.Subasta != null && Model.Subasta.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm table-striped align-middle">
                        <thead>
                            <tr>
                                <th>Id Subasta</th>
                                <th>Fecha inicio</th>
                                <th>Fecha cierre</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.Subasta.OrderByDescending(x => x.FechaInicio))
                            {
                                <tr>
                                    <td>@s.SubastaId</td>
                                    <td>@s.FechaInicio.ToString("dd/MM/yyyy")</td>
                                    <td>@s.FechaCierre.ToString("dd/MM/yyyy")</td>
                                    <td>@(s.EstadoSubasta?.NombreEstado ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">
                    Esta joya todavía no ha participado en ninguna subasta.
                </p>
            }
        </section>

        <hr class="my-4" />

        <!-- 🔁 Acciones -->
        <div class="d-flex flex-column flex-sm-row gap-2 justify-content-end">
            <a asp-action="Delete" asp-route-id="@Model.JoyaId" class="btn btn-outline-danger">
                <i class="bi bi-trash me-1"></i> Eliminar
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Regresar al listado
            </a>
        </div>

    </div>
</article>