@model Maven.Application.DTOs.JoyaDTO

@{
    ViewData["Title"] = "Editar joya";
}

<header class="mb-3">
    <h1 class="h3 mb-0">Editar joya</h1>
    <p class="text-muted mb-0">Mantenimiento: actualización de la joya</p>
</header>

<form asp-action="Edit" method="post" asp-route-id="@Model.JoyaId" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input asp-for="JoyaId" type="hidden" />

    <div class="col-md-6">
        <label asp-for="VendedorId" class="form-label"></label>
        <select asp-for="VendedorId" class="form-select" asp-items="ViewBag.VendedorId">
            <option value="">-- Seleccione un vendedor --</option>
        </select>
        <span asp-validation-for="VendedorId" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="EstadoObjetoId" class="form-label"></label>
        <select asp-for="EstadoObjetoId" class="form-select" asp-items="ViewBag.EstadoObjetoId">
            <option value="">-- Seleccione un estado --</option>
        </select>
        <span asp-validation-for="EstadoObjetoId" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="CondicionObjetoId" class="form-label"></label>
        <select asp-for="CondicionObjetoId" class="form-select" asp-items="ViewBag.CondicionObjetoId">
            <option value="">-- Seleccione una condición --</option>
        </select>
        <span asp-validation-for="CondicionObjetoId" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="Nombre" class="form-label"></label>
        <input asp-for="Nombre" class="form-control" autocomplete="off" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="Descripcion" class="form-label"></label>
        <textarea asp-for="Descripcion" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Descripcion" class="text-danger"></span>
    </div>

    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check2-circle"></i> Guardar cambios
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}