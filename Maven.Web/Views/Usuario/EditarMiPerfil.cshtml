@model Maven.Application.DTOs.UsuarioDTO

@{
    ViewData["Title"] = "Editar Mi Perfil";
}

<div class="container mt-5" style="max-width: 600px;">

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">

            <h3 class="mb-4 text-center fw-semibold">Editar Mi Perfil</h3>


            <form asp-action="EditarMiPerfil" method="post">
                <input type="hidden" asp-for="UsuarioId" />

                <!-- Nombre -->
                <div class="mb-3">
                    <label asp-for="NombreCompleto" class="form-label fw-semibold"></label>
                    <input asp-for="NombreCompleto" class="form-control rounded-3" placeholder="Ingrese su nombre completo" />
                    <span asp-validation-for="NombreCompleto" class="text-danger small"></span>
                </div>

                <!-- Correo -->
                <div class="mb-4">
                    <label asp-for="Correo" class="form-label fw-semibold"></label>
                    <input asp-for="Correo" class="form-control rounded-3" placeholder="Ingrese su correo electrónico" />
                    <span asp-validation-for="Correo" class="text-danger small"></span>
                </div>

                <!-- Botones -->
                <div class="d-flex justify-content-between">
                    <button type="submit" class="btn btn-success px-4 rounded-pill">
                        <i class="bi bi-check-circle me-1"></i> Guardar
                    </button>

                    <a asp-action="MiPerfil" class="btn btn-outline-secondary px-4 rounded-pill">
                        Cancelar
                    </a>
                </div>

            </form>
        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}