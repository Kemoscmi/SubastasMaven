@model Maven.Application.DTOs.UsuarioDTO

@{
    ViewData["Title"] = "Crear Usuario";
}

<div class="container mt-5" style="max-width: 600px;">

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">

            <h3 class="text-center fw-semibold mb-4">Crear Usuario</h3>

            <div asp-validation-summary="All" class="alert alert-danger"></div>

            <form asp-action="Create" method="post">

                <!-- Nombre -->
                <div class="mb-3">
                    <label asp-for="NombreCompleto" class="form-label fw-semibold"></label>
                    <input asp-for="NombreCompleto" class="form-control rounded-3" placeholder="Nombre completo" />
                    <span asp-validation-for="NombreCompleto" class="text-danger small"></span>
                </div>

                <!-- Correo -->
                <div class="mb-3">
                    <label asp-for="Correo" class="form-label fw-semibold"></label>
                    <input asp-for="Correo" class="form-control rounded-3" placeholder="Correo electrónico" />
                    <span asp-validation-for="Correo" class="text-danger small"></span>
                </div>

                <!-- Contraseña -->
                <div class="mb-3">
                    <label asp-for="PasswordHash" class="form-label fw-semibold"></label>
                    <input asp-for="PasswordHash" type="password" class="form-control rounded-3" placeholder="Contraseña" />
                    <span asp-validation-for="PasswordHash" class="text-danger small"></span>
                </div>

                <!-- Rol -->
                <div class="mb-3">
                    <label asp-for="RolId" class="form-label fw-semibold"></label>
                    <select asp-for="RolId" asp-items="ViewBag.RolId" class="form-select rounded-3">
                        <option value="">Seleccione un rol</option>
                    </select>
                    <span asp-validation-for="RolId" class="text-danger small"></span>
                </div>

          

                <!-- Botones -->
                <div class="d-flex justify-content-between">
                    <button type="submit" class="btn btn-success px-4 rounded-pill">
                        <i class="bi bi-check-circle me-1"></i> Guardar
                    </button>

                    <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">
                        Cancelar
                    </a>
                </div>

            </form>
        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}