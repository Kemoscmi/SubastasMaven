@model List<Maven.Application.DTOs.UsuarioDTO>

@{
    ViewData["Title"] = "Usuarios";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-2 mb-4">
    <div>
        <h2 class="mb-1">Usuarios</h2>
        <p class="text-muted mb-0">Listado de usuarios registrados en el sistema.</p>
    </div>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info mb-0">
        No hay usuarios registrados.
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Nombre completo</th>
                            <th>Rol</th>
                            <th>Estado</th>
                            <th class="text-end pe-3">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var u in Model)
                        {
                            var rol = u.Rol?.NombreRol ?? "-";
                            var estado = u.EstadoUsuario?.NombreEstado ?? "-";

                            var estadoUpper = estado.ToUpperInvariant();
                            var claseEstado =
                            estadoUpper.Contains("ACTIV") ? "text-bg-success" :
                            estadoUpper.Contains("INACTIV") ? "text-bg-danger" :
                            "text-bg-secondary";

                            <tr>
                                <td class="ps-3 fw-semibold">
                                    @u.NombreCompleto
                                </td>

                                <td>
                                    <span class="badge text-bg-primary">
                                        @rol
                                    </span>
                                </td>

                                <td>
                                    <span class="badge @claseEstado">
                                        @estado
                                    </span>
                                </td>

                                <td class="text-end pe-3">
                                    <a class="btn btn-sm btn-outline-primary"
                                       asp-action="Detalle"
                                       asp-route-id="@u.UsuarioId">
                                        <i class="bi bi-eye me-1"></i>
                                        Ver detalle
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>
}