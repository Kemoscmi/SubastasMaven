@model Maven.Application.DTOs.UsuarioDTO

@{
    ViewData["Title"] = "Editar usuario";
}

<header class="mb-3">
    <h1 class="h3 mb-0">Editar usuario</h1>
    <p class="text-muted mb-0">Mantenimiento: actualización del usuario</p>
</header>



@if (ViewBag.ErroresDebug != null)
{
    <div class="alert alert-danger">
        <strong>Errores detectados:</strong>
        <ul class="mb-0">
            @foreach (string error in ViewBag.ErroresDebug)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

<form asp-action="Edit" method="post" asp-route-id="@Model.UsuarioId" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input asp-for="UsuarioId" type="hidden" />

    <div class="col-12">
        <label asp-for="NombreCompleto" class="form-label"></label>
        <input asp-for="NombreCompleto" class="form-control" autocomplete="off" />
        <span asp-validation-for="NombreCompleto" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Correo" class="form-label"></label>
        <input asp-for="Correo" class="form-control" autocomplete="off" />
        <span asp-validation-for="Correo" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label class="form-label">Rol</label>
        <input type="text" class="form-control" value="@Model.Rol?.NombreRol" readonly />
        <div class="form-text">Este campo no es editable en este avance.</div>
    </div>

    <div class="col-md-6">
        <label class="form-label">Estado actual</label>
        <input type="text" class="form-control" value="@Model.EstadoUsuario?.NombreEstado" readonly />
        <div class="form-text">Este campo se cambia mediante bloqueo o activación.</div>
    </div>

    <div class="col-md-6">
        <label class="form-label">Fecha de registro</label>
        <input type="text" class="form-control" value="@Model.FechaRegistro.ToString("dd/MM/yyyy")" readonly />
        <div class="form-text">Este campo no es editable en este avance.</div>
    </div>

    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check2-circle"></i> Guardar cambios
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}