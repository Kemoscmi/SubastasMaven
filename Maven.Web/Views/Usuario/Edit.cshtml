@model Maven.Application.DTOs.UsuarioDTO

@{
    ViewData["Title"] = "Editar usuario";
}

<header class="mb-3">
    <h1 class="h3 mb-0">Editar usuario</h1>
    <p class="text-muted mb-0">Mantenimiento: actualización del usuario</p>
</header>

<form asp-action="Edit" method="post" asp-route-id="@Model.UsuarioId" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input asp-for="UsuarioId" type="hidden" />

    <div class="col-12">
        <label asp-for="NombreCompleto" class="form-label"></label>
        <input asp-for="NombreCompleto" class="form-control" autocomplete="off" />
        <span asp-validation-for="NombreCompleto" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Correo" class="form-label"></label>
        <input asp-for="Correo" class="form-control" autocomplete="off" />
        <span asp-validation-for="Correo" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="PasswordHash" class="form-label"></label>
        <input asp-for="PasswordHash" type="password" class="form-control" autocomplete="new-password" />
        <span asp-validation-for="PasswordHash" class="text-danger"></span>
        <div class="form-text">Si no vas a cambiarla, dejala igual que estaba.</div>
    </div>

    <div class="col-md-6">
        <label asp-for="RolId" class="form-label"></label>
        <select asp-for="RolId" class="form-select" asp-items="ViewBag.RolId">
            <option value="">-- Seleccione un rol --</option>
        </select>
        <span asp-validation-for="RolId" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="EstadoUsuarioId" class="form-label"></label>
        <select asp-for="EstadoUsuarioId" class="form-select" asp-items="ViewBag.EstadoUsuarioId">
            <option value="">-- Seleccione un estado --</option>
        </select>
        <span asp-validation-for="EstadoUsuarioId" class="text-danger"></span>
    </div>

    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check2-circle"></i> Guardar cambios
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}