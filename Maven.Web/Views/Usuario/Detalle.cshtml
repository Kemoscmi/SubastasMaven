@model Maven.Application.DTOs.UsuarioDTO

@{
    ViewData["Title"] = "Detalle de Usuario";

    var rolNombre = Model.Rol?.NombreRol ?? "No disponible";
    var estadoNombre = Model.EstadoUsuario?.NombreEstado ?? "No disponible";

    var estadoUpper = estadoNombre.ToUpperInvariant();
    var claseEstado = estadoUpper.Contains("ACTIV") ? "text-bg-success"
                    : estadoUpper.Contains("INACTIV") ? "text-bg-danger"
                    : "text-bg-secondary";
}

<nav class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Inicio</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-controller="Usuario" asp-action="Index" class="text-decoration-none">Usuarios</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Detalle</li>
    </ol>
</nav>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
    <div>
        <h1 class="h3 mb-1">Detalle de usuario</h1>
        <p class="text-muted mb-0">Información del perfil y actividad dentro del sistema.</p>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.UsuarioId" class="btn btn-outline-primary">
            <i class="bi bi-pencil-square me-1"></i> Editar
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Volver
        </a>
    </div>
</div>

<article class="card shadow-sm border-0">
    <div class="card-body p-4">


        <header class="mb-4">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3">
                <div>
                    <h2 class="h4 fw-semibold mb-2">@Model.NombreCompleto</h2>

                    <div class="d-flex flex-wrap gap-2 align-items-center">
                        <span class="badge text-bg-light border">
                            <i class="bi bi-envelope me-1"></i>
                            @Model.Correo
                        </span>

                        <span class="badge text-bg-primary">
                            <i class="bi bi-person-badge me-1"></i>
                            @rolNombre
                        </span>

                        <span class="badge @claseEstado">
                            <i class="bi bi-shield-check me-1"></i>
                            @estadoNombre
                        </span>
                    </div>
                </div>

                <div class="text-md-end">
                    <div class="text-muted small">ID Usuario</div>
                    <span class="badge text-bg-light border fs-6">#@Model.UsuarioId</span>
                </div>
            </div>
        </header>

        <hr class="my-4" />

   
        <section class="row g-4 mb-4">

            <div class="col-12 col-lg-7">
                <div class="card border-0 bg-light h-100">
                    <div class="card-body p-4">
                        <h3 class="h5 mb-3">Información básica del perfil</h3>

                        <ul class="list-group list-group-flush">
                            <li class="list-group-item bg-light px-0 py-3 d-flex justify-content-between">
                                <span class="text-muted">Nombre completo</span>
                                <span class="fw-semibold">@Model.NombreCompleto</span>
                            </li>

                            <li class="list-group-item bg-light px-0 py-3 d-flex justify-content-between">
                                <span class="text-muted">Correo</span>
                                <span class="fw-semibold">@Model.Correo</span>
                            </li>

                            <li class="list-group-item bg-light px-0 py-3 d-flex justify-content-between">
                                <span class="text-muted">Rol</span>
                                <span class="badge text-bg-primary">@rolNombre</span>
                            </li>

                            <li class="list-group-item bg-light px-0 py-3 d-flex justify-content-between">
                                <span class="text-muted">Estado</span>
                                <span class="badge @claseEstado">@estadoNombre</span>
                            </li>

                            <li class="list-group-item bg-light px-0 py-3 d-flex justify-content-between">
                                <span class="text-muted">Fecha de registro</span>
                                <span class="fw-semibold">@Model.FechaRegistro.ToString("dd/MM/yyyy")</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-5">
                <div class="card border-0 bg-light h-100">
                    <div class="card-body p-4">
                        <h3 class="h5 mb-3">Actividad en el sistema</h3>

                        <div class="row g-3">
                            <div class="col-12">
                                <div class="card border-0 shadow-sm">
                                    <div class="card-body d-flex justify-content-between">
                                        <div class="text-muted small">Subastas creadas</div>
                                        <div class="display-6">@Model.CantidadSubastasCreadas</div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="card border-0 shadow-sm">
                                    <div class="card-body d-flex justify-content-between">
                                        <div class="text-muted small">Pujas realizadas</div>
                                        <div class="display-6">@Model.CantidadPujasRealizadas</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </section>

        <hr class="my-4" />

      
        <div class="d-flex flex-column flex-sm-row gap-2 justify-content-end">

            <form asp-action="CambiarEstado" method="post">
                @Html.AntiForgeryToken()  

                <input type="hidden" name="id" value="@Model.UsuarioId" />

                @if (Model.EstadoUsuario?.NombreEstado.ToUpper().Contains("ACTIV") == true)
                {
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-person-x me-1"></i> Desactivar
                    </button>
                }
                else
                {
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-person-check me-1"></i> Activar
                    </button>
                }
            </form>

            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Regresar al listado
            </a>

        </div>

    </div>
</article>