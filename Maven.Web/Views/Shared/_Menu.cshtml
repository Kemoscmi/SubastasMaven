<nav class="navbar navbar-expand-lg mj-nav">
    <div class="container">
        <a class="navbar-brand fw-semibold mj-brand" asp-action="Index" asp-controller="Home">
            <i class="bi bi-gem me-2 mj-gold"></i>MAVEN Jewelry
        </a>

        <button class="navbar-toggler mj-toggler" type="button"
                data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                <!-- Catálogo: TODOS -->
                <li class="nav-item">
                    <a class="nav-link mj-navlink" asp-controller="Joya" asp-action="Index">
                        <i class="bi bi-grid me-1"></i>Catálogo
                    </a>
                </li>

                <!-- PROCESO: TODOS LOS LOGUEADOS -->
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle mj-navlink" href="#" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-gear-fill me-1"></i>Proceso
                        </a>
                        <ul class="dropdown-menu">

                            <!-- Crear -->
                            @if (!User.IsInRole("COMPRADOR"))
                            {
                                <li>
                                    <a class="dropdown-item fw-semibold text-primary" asp-action="Create" asp-controller="Subasta">
                                        <i class="bi bi-plus-circle me-2"></i>Crear subasta
                                    </a>
                                </li>

                                <li><hr class="dropdown-divider"></li>
                            }

                            <!-- Activas -->
                            <li>
                                <a class="dropdown-item" asp-action="Activas" asp-controller="Subasta">
                                    <i class="bi bi-lightning-charge me-2"></i>Subastas activas
                                </a>
                            </li>

                            <!-- Finalizadas -->
                            <li>
                                <a class="dropdown-item" asp-action="Finalizadas" asp-controller="Subasta">
                                    <i class="bi bi-check-circle me-2"></i>Subastas finalizadas
                                </a>
                            </li>

                        </ul>
                    </li>
                }

                <!-- ADMIN: VE TODO -->
                @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("ADMIN") || User.IsInRole("VENDEDOR"))
                {
                    <!-- Mantenimiento -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle mj-navlink" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-wrench-adjustable me-1"></i>Mantenimiento
                        </a>
                        <ul class="dropdown-menu mj-dd">
                            <li>
                                <a class="dropdown-item" asp-controller="Usuario" asp-action="Index">
                                    Usuarios
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="Joya" asp-action="Index">
                                    Joyas
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="Subasta" asp-action="Index">
                                    Subastas
                                </a>
                            </li>
                        </ul>
                    </li>
                }

                 @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("ADMIN"))
                {
                    <!-- Reportes -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle mj-navlink" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-bar-chart-line me-1"></i>Reportes
                        </a>
                        <ul class="dropdown-menu mj-dd">
                            <li>
                                <a class="dropdown-item" asp-controller="Reporte" asp-action="SubastasFinalizadas">
                                    Subastas finalizadas (PDF)
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="Reporte" asp-action="Categorias">
                                    Subastas por categoría
                                </a>
                            </li>
                        </ul>
                    </li>
               }

            </ul>

            <!-- PERFIL -->
            <ul class="navbar-nav ms-auto">
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle d-flex align-items-center mj-navlink" href="#" data-bs-toggle="dropdown">
                        <img class="rounded-circle me-2 border"
                             src="~/images/profile.png"
                             width="32" height="32" />
                        <span class="d-none d-sm-inline">
                            @(User.Identity != null && User.Identity.IsAuthenticated
                                                        ? User.Identity.Name
                                                        : "Invitado")
                        </span>
                    </a>

                    <ul class="dropdown-menu dropdown-menu-end mj-dd">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li>
                                <a class="dropdown-item" asp-controller="Usuario" asp-action="MiPerfil">
                                    Mi Perfil
                                </a>
                            </li>

                            <li><hr class="dropdown-divider"></li>

                            <li>
                                <a class="dropdown-item" asp-controller="Login" asp-action="LogOff">
                                    Salir
                                </a>
                            </li>
                        }
                        else
                        {
                            <li>
                                <a class="dropdown-item" asp-controller="Login" asp-action="Index">
                                    Ingresar
                                </a>
                            </li>
                        }
                    </ul>
                </li>
            </ul>

        </div>
    </div>
</nav>