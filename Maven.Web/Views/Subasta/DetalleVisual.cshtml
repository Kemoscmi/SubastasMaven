@model Maven.Application.DTOs.Subasta.SubastaDetalleVisualDTO
@{
    ViewData["Title"] = "Detalle de Subasta";
    var origen = ViewBag.Origen as string;
}

<h2 class="mb-3">Detalle de Subasta #@Model.SubastaId</h2>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
                {
                    <img src="@Model.ImagenUrl" class="img-fluid rounded" style="width:100%; height:320px; object-fit:cover;" />
                }
                else
                {
                    <div class="border rounded p-4 text-muted text-center" style="height:320px; display:flex; align-items:center; justify-content:center;">
                        Sin imagen
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-body">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-gem"></i>
                    <strong>Objeto subastado</strong>
                </div>
            </div>

            <div class="card-body">
                <h4 class="mb-1">@Model.NombreJoya</h4>
                <p class="text-muted mb-3">@Model.DescripcionJoya</p>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="small text-muted">Condición</div>
                        <div class="fw-semibold">
                            @(string.IsNullOrWhiteSpace(Model.Condicion) ? "Sin condición" : Model.Condicion)
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="small text-muted">Categorías</div>
                        <div class="fw-semibold">
                            @if (Model.Categorias.Any())
                            {
                                @string.Join(", ", Model.Categorias)
                            }
                            else
                            {
                                <span class="text-muted">Sin categorías</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-body">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-hammer"></i>
                    <strong>Información de la subasta</strong>
                </div>
            </div>

            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="small text-muted">Fecha inicio</div>
                        <div class="fw-semibold">@Model.FechaInicio.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted">Fecha cierre</div>
                        <div class="fw-semibold">@Model.FechaCierre.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>

                    <div class="col-md-6">
                        <div class="small text-muted">Precio base</div>
                        <div class="fw-semibold">₡@Model.PrecioBase.ToString("N0")</div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted">Incremento mínimo</div>
                        <div class="fw-semibold">₡@Model.IncrementoMinimo.ToString("N0")</div>
                    </div>

                    <div class="col-md-6">
                        <div class="small text-muted">Estado actual</div>
                        <div class="fw-semibold">@Model.EstadoActual</div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted">Cantidad total de pujas</div>
                        <div class="fw-semibold">@Model.CantidadPujas</div>
                    </div>

                    <div class="col-12">
                        <div class="small text-muted">Vendedor</div>
                        <div class="fw-semibold">@Model.Vendedor</div>
                    </div>
                </div>

                <hr class="my-3" />

                <a class="btn btn-outline-secondary"
                   asp-action="HistorialPujas"
                   asp-route-id="@Model.SubastaId"
                   asp-route-origen="@origen"
                   asp-route-desdeDetalle="true">
                    <i class="bi bi-clock-history me-1"></i>Ver historial de pujas
                </a>
                    @if (origen == "finalizadas")
                    {
                        <a class="maven-back" asp-action="Finalizadas">
                            ← Volver a subastas finalizadas
                        </a>
                    }
                    else if (origen == "borradores")
                    {
                        <a class="maven-back" asp-action="Borradores">
                            ← Volver a subastas editables
                        </a>
                    }
                    else if (origen == "index")
                    {
                        <a class="maven-back" asp-action="Index">
                            ← Volver a todas las subastas
                        </a>
                    }
                    else
                    {
                        <a class="maven-back" asp-action="Activas">
                            ← Volver a subastas activas
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>