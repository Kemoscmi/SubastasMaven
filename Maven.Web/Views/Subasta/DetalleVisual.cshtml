@model Maven.Application.DTOs.Subasta.SubastaDetalleVisualDTO
@{
    ViewData["Title"] = "Detalle de Subasta";
    var origen = ViewBag.Origen as string;

    string estadoClase = "bg-secondary";
    if (Model.EstadoActual?.ToUpper() == "ACTIVA")
    {
        estadoClase = "bg-success";
    }
    else if (Model.EstadoActual?.ToUpper() == "FINALIZADA")
    {
        estadoClase = "bg-dark";
    }
    else if (Model.EstadoActual?.ToUpper() == "PUBLICADA")
    {
        estadoClase = "bg-primary";
    }
    else if (Model.EstadoActual?.ToUpper() == "CANCELADA")
    {
        estadoClase = "bg-danger";
    }

    bool sinPujas = Model.CantidadPujas == 0;
    bool finalizada = Model.Finalizada || (Model.EstadoActual?.ToUpper() == "FINALIZADA");
    bool cancelada = Model.EstadoActual?.ToUpper() == "CANCELADA";
    bool cerrada = finalizada || cancelada;
    bool huboPujas = Model.CantidadPujas > 0;
}

<style>
    .subasta-page-title {
        font-weight: 700;
        letter-spacing: .2px;
    }

    .subasta-card {
        border: 0;
        border-radius: 18px;
        box-shadow: 0 6px 18px rgba(0,0,0,.08);
        overflow: hidden;
    }

        .subasta-card .card-header {
            background: #fff;
            border-bottom: 1px solid #f1f1f1;
            font-weight: 600;
            padding: 1rem 1.25rem;
        }

        .subasta-card .card-body {
            padding: 1.25rem;
        }

    .subasta-main-image {
        width: 100%;
        height: 400px;
        object-fit: cover;
        border-radius: 14px;
    }

    .subasta-placeholder {
        height: 400px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px dashed #d9d9d9;
        border-radius: 14px;
        color: #7a7a7a;
        background: #fafafa;
        font-weight: 500;
    }

    .subasta-label {
        font-size: .92rem;
        color: #6c757d;
        margin-bottom: .15rem;
    }

    .subasta-value {
        font-size: 1.05rem;
        font-weight: 600;
        color: #1f2937;
    }

    .subasta-value-strong {
        font-size: 1.1rem;
        font-weight: 700;
    }

    .puja-actual {
        color: #198754;
        font-size: 2rem;
        font-weight: 800;
        line-height: 1;
    }

    .lider-box {
        background: #f8fafc;
        border: 1px solid #e9ecef;
        border-radius: 14px;
        padding: 1rem;
    }

    .lider-nombre {
        font-size: 1.2rem;
        font-weight: 700;
        color: #111827;
    }

    .contador-box {
        background: linear-gradient(135deg, #fff5f5, #fff);
        border: 1px solid #f3d6d6;
        border-radius: 16px;
        padding: 1rem 1.1rem;
    }

    .contador-texto {
        font-size: 2rem;
        font-weight: 800;
        line-height: 1;
        letter-spacing: 1px;
    }

    .contador-activo {
        color: #dc3545;
    }

    .contador-finalizado {
        color: #495057;
    }

    .chip-categoria {
        display: inline-block;
        padding: .4rem .7rem;
        margin: .15rem .25rem .15rem 0;
        border-radius: 999px;
        background: #f4f4f5;
        color: #222;
        font-size: .88rem;
        font-weight: 600;
    }

    .estado-badge {
        font-size: .82rem;
        padding: .55rem .8rem;
        border-radius: 999px;
        letter-spacing: .3px;
    }

    .tiempo-real-pill {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        padding: .45rem .8rem;
        border-radius: 999px;
        background: #eefaf2;
        color: #198754;
        font-size: .86rem;
        font-weight: 700;
        border: 1px solid #d8f1e1;
    }

    .tiempo-real-dot {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: #198754;
        display: inline-block;
    }

    .historial-title {
        font-weight: 700;
    }

    .tabla-historial thead th {
        background: #f8f9fa;
        font-weight: 700;
        border-bottom-width: 1px;
    }

    .tabla-historial tbody tr:hover {
        background: #fcfcfd;
    }

    .mensaje-finalizada {
        border-radius: 16px;
        border: 1px solid #e5e7eb;
        background: linear-gradient(135deg, #f8f9fa, #ffffff);
    }

    .sin-pujas-box {
        border-radius: 16px;
        border: 1px dashed #cfd4da;
        background: #fafafa;
        padding: 1.2rem;
        text-align: center;
        color: #6c757d;
    }

        .sin-pujas-box i {
            font-size: 1.8rem;
            margin-bottom: .5rem;
            display: block;
        }

    .maven-back {
        text-decoration: none;
    }

    .puja-final-card {
        border: 1px solid #ece7df;
        background: linear-gradient(180deg, #fffdf9 0%, #ffffff 100%);
    }

        .puja-final-card .card-header {
            background: linear-gradient(90deg, #fff8ef 0%, #ffffff 100%);
            border-bottom: 1px solid #f2e8da;
        }

    .puja-input {
        border-radius: 14px;
        border: 1px solid #d6dbe1;
        box-shadow: none;
    }

        .puja-input:focus {
            border-color: #c8a96b;
            box-shadow: 0 0 0 .15rem rgba(200, 169, 107, 0.15);
        }

    #btnRegistrarPuja {
        border-radius: 14px;
        font-weight: 700;
        letter-spacing: .2px;
        min-height: 56px;
    }

    #mensajePuja .alert {
        border-radius: 14px;
    }
</style>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
    <div>
        <h2 class="mb-1 subasta-page-title">Detalle de Subasta #@Model.SubastaId</h2>
        <div class="text-muted">Visualización completa de la subasta en tiempo real</div>
    </div>

    <div class="d-flex align-items-center gap-2 flex-wrap">
        <span class="badge @estadoClase estado-badge" id="estadoBadge">@Model.EstadoActual</span>

        <div class="tiempo-real-pill" id="estadoConexion">
            <span class="tiempo-real-dot"></span>
            Tiempo real conectado
        </div>
    </div>
</div>

<input type="hidden" id="subastaId" value="@Model.SubastaId" />
<input type="hidden" id="fechaCierreIso" value="@Model.FechaCierre.ToString("yyyy-MM-ddTHH:mm:ss")" />
<input type="hidden" id="urlPagoDetalle" value="@Url.Action("Detalle", "Pago")" />
<div id="alertaTiempoReal" class="mb-3"></div>

@if (cerrada)
{
    <div class="alert mensaje-finalizada mb-4">
        <div class="d-flex align-items-start gap-3">
            <i class="bi bi-flag-fill fs-4 text-dark"></i>
            <div>
                @if (finalizada && huboPujas)
                {
                    <div class="fw-bold mb-1">Subasta finalizada con ganador</div>
                    <div class="text-muted">
                        Ganador: <strong>@Model.UsuarioLider</strong><br />
                        Monto final: <strong>₡@Model.PujaActual.ToString("N0")</strong>
                    </div>
                }
                else if (finalizada && !huboPujas)
                {
                    <div class="fw-bold mb-1">Subasta finalizada sin ofertas</div>
                    <div class="text-muted">
                        Esta subasta llegó a su fecha de cierre, pero no recibió pujas.
                    </div>
                }
                else if (cancelada)
                {
                    <div class="fw-bold mb-1">Subasta cancelada</div>
                    <div class="text-muted">
                        Esta subasta fue cancelada y ya no admite nuevas pujas.
                    </div>
                }
            </div>
        </div>
    </div>
}
<div class="row g-4">
    <div class="col-lg-4">
        <div class="card subasta-card h-100">
            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
                {
                    <img src="@Model.ImagenUrl" class="subasta-main-image" alt="Imagen de la joya" />
                }
                else
                {
                    <div class="subasta-placeholder">
                        Sin imagen disponible
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card subasta-card mb-4">
            <div class="card-header">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-gem"></i>
                    <span>Objeto subastado</span>
                </div>
            </div>

            <div class="card-body">
                <h3 class="mb-2 fw-bold">@Model.NombreJoya</h3>
                <p class="text-muted mb-4">@Model.DescripcionJoya</p>

                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="subasta-label">Condición</div>
                        <div class="subasta-value">
                            @(string.IsNullOrWhiteSpace(Model.Condicion) ? "Sin condición" : Model.Condicion)
                        </div>
                    </div>

                    <div class="col-md-8">
                        <div class="subasta-label">Categorías</div>
                        <div class="subasta-value">
                            @if (Model.Categorias.Any())
                            {
                                @foreach (var categoria in Model.Categorias)
                                {
                                    <span class="chip-categoria">@categoria</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">Sin categorías</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card subasta-card">
            <div class="card-header">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-hammer"></i>
                    <span>Información de la subasta</span>
                </div>
            </div>

            <div class="card-body">
                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="subasta-label">Fecha inicio</div>
                        <div class="subasta-value">@Model.FechaInicio.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>

                    <div class="col-md-6">
                        <div class="subasta-label">Fecha cierre</div>
                        <div class="subasta-value">@Model.FechaCierre.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>

                    <div class="col-md-6">
                        <div class="subasta-label">Precio base</div>
                        <div class="subasta-value">₡@Model.PrecioBase.ToString("N0")</div>
                    </div>

                    <div class="col-md-6">
                        <div class="subasta-label">Incremento mínimo</div>
                        <div class="subasta-value">₡@Model.IncrementoMinimo.ToString("N0")</div>
                    </div>
                </div>

                <div class="row g-4 align-items-stretch">
                    <div class="col-md-6">
                        <div class="h-100">
                            <div class="subasta-label">Puja actual</div>
                            <div class="puja-actual" id="pujaActual">
                                @if (Model.TienePujas)
                                {
                                    @:₡@Model.PujaActual.ToString("N0")
                                }
                                else
                                {
                                    <span class="text-muted fs-5">Sin pujas</span>
                                }
                            </div>

                            <div class="mt-4 subasta-label">Vendedor</div>
                            <div class="subasta-value">@Model.Vendedor</div>

                            <div class="mt-4 subasta-label">Cantidad total de pujas</div>
                            <div class="subasta-value-strong" id="cantidadPujas">@Model.CantidadPujas</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="lider-box mb-3">
                            <div class="subasta-label">Usuario líder</div>
                            <div class="lider-nombre" id="usuarioLider">@Model.UsuarioLider</div>
                        </div>

                        <div class="contador-box">
                            <div class="subasta-label">Tiempo restante</div>
                            <div class="contador-texto" id="contadorSubasta">Calculando...</div>

                            <div class="mt-3 subasta-label">Estado actual</div>
                            <div class="subasta-value-strong" id="estadoActual">@Model.EstadoActual</div>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                    <h5 class="mb-0 historial-title">Historial de pujas</h5>

                    <a class="btn btn-outline-secondary btn-sm"
                       asp-action="HistorialPujas"
                       asp-route-id="@Model.SubastaId"
                       asp-route-origen="@origen"
                       asp-route-desdeDetalle="true">
                        <i class="bi bi-clock-history me-1"></i>Ver historial completo
                    </a>
                </div>

                @if (!cerrada)
                {
                    <div id="sinPujasBox" class="@(sinPujas ? "" : "d-none")">
                        <div class="sin-pujas-box">
                            <i class="bi bi-inbox"></i>
                            <div class="fw-bold mb-1">Todavía no hay pujas registradas</div>
                            <div>Cuando se registre la primera puja, aparecerá aquí automáticamente.</div>
                        </div>
                    </div>
                }

                <div id="tablaHistorialWrapper" class="table-responsive @((sinPujas || cancelada && !huboPujas) ? "d-none" : "")">
                    <table class="table table-bordered table-hover align-middle tabla-historial mb-0">
                        <thead>
                            <tr>
                                <th>Usuario</th>
                                <th>Monto ofertado</th>
                                <th>Fecha y hora</th>
                            </tr>
                        </thead>
                        <tbody id="tbodyHistorial">
                            @foreach (var p in Model.HistorialPujas)
                            {
                                <tr>
                                    <td>@p.Usuario</td>
                                    <td>₡@p.MontoOfertado.ToString("N0")</td>
                                    <td>@p.FechaHora.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (!cerrada)
                {
                    <div id="contenedorPuja" class="card subasta-card mt-4 puja-final-card @(Model.EstadoActual?.ToUpper() == "ACTIVA" ? "" : "d-none")">
                        <div class="card-header">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-cash-stack"></i>
                                <span>Realizar nueva puja</span>
                            </div>
                        </div>

                        <div class="card-body">
                            <div class="mb-3">
                                <div class="subasta-label">Puja actual</div>
                                <div class="puja-actual mb-2" id="pujaActualFooter">
                                    @if (Model.TienePujas)
                                    {
                                        @:₡@Model.PujaActual.ToString("N0")
                                    }
                                    else
                                    {
                                        @:₡@Model.PrecioBase.ToString("N0")
                                    }
                                </div>

                                <div class="form-text">
                                    La nueva oferta debe ser mayor a la actual y respetar el incremento mínimo de
                                    <strong>₡@Model.IncrementoMinimo.ToString("N0")</strong>.
                                </div>
                            </div>

                            <form id="formPuja" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="SubastaId" value="@Model.SubastaId" />

                                <div class="row g-3 align-items-end">
                                    <div class="col-lg-8">
                                        <label class="form-label fw-semibold">Monto ofertado</label>
                                        <input type="number"
                                               step="1"
                                               min="1"
                                               class="form-control form-control-lg puja-input"
                                               id="montoOfertado"
                                               name="MontoOfertado"
                                               placeholder="Ingrese su oferta"
                                               inputmode="numeric" />
                                    </div>

                                    <div class="col-lg-4 d-grid">
                                        <button type="submit" class="btn btn-dark btn-lg" id="btnRegistrarPuja">
                                            <i class="bi bi-hammer me-1"></i> Registrar puja
                                        </button>
                                    </div>
                                </div>
                            </form>

                            <div id="mensajePuja" class="mt-3"></div>
                        </div>
                    </div>
                }
                else if (cerrada)
                {
                    <div class="card subasta-card mt-4">
                        <div class="card-body text-center py-4">
                            <i class="bi bi-flag-fill fs-2 text-dark mb-2 d-block"></i>

                            @if (finalizada && huboPujas)
                            {
                                <h5 class="fw-bold mb-2">Resultado final registrado</h5>
                                <p class="text-muted mb-3">
                                    La subasta cerró correctamente y ya no admite nuevas pujas.
                                </p>

                                <a asp-controller="Pago"
                                   asp-action="Detalle"
                                   asp-route-subastaId="@Model.SubastaId"
                                   class="btn btn-success">
                                    <i class="bi bi-credit-card me-1"></i> Ver pago
                                </a>
                            }
                            else if (finalizada && !huboPujas)
                            {
                                <h5 class="fw-bold mb-2">Subasta finalizada sin pujas</h5>
                                <p class="text-muted mb-0">
                                    No se registraron ofertas durante el tiempo de la subasta.
                                </p>
                            }
                            else if (cancelada)
                            {
                                <h5 class="fw-bold mb-2">Subasta cancelada</h5>
                                <p class="text-muted mb-0">
                                    Esta subasta ya no se encuentra disponible para participar.
                                </p>
                            }
                        </div>
                    </div>
                }

                <div id="contenedorPostCierre"></div>

                <div class="mt-4">
                    @if (origen == "finalizadas")
                    {
                        <a class="btn btn-outline-dark" asp-action="Finalizadas">
                            ← Volver a subastas finalizadas
                        </a>
                    }
                    else if (origen == "borradores")
                    {
                        <a class="btn btn-outline-dark" asp-action="Borradores">
                            ← Volver a subastas editables
                        </a>
                    }
                    else if (origen == "index")
                    {
                        <a class="btn btn-outline-dark" asp-action="Index">
                            ← Volver a todas las subastas
                        </a>
                    }
                    else
                    {
                        <a class="btn btn-outline-dark" asp-action="Activas">
                            ← Volver a subastas activas
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="modalSubastaFinalizada" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 22px; overflow: hidden;">
            <div class="modal-body p-4 text-center">
                <div class="mb-3">
                    <div style="width:72px;height:72px;border-radius:50%;background:#f8f9fa;display:flex;align-items:center;justify-content:center;margin:0 auto;">
                        <i class="bi bi-trophy-fill fs-2 text-warning"></i>
                    </div>
                </div>

                <h4 class="fw-bold mb-2" id="modalTituloSubasta">Subasta finalizada</h4>
                <p class="text-muted mb-3" id="modalTextoSubasta">
                    La subasta ha concluido correctamente.
                </p>

                <div id="modalDetalleGanador" class="mb-3"></div>

                <button type="button" class="btn btn-dark px-4" data-bs-dismiss="modal">
                    Entendido
                </button>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>

    <script>
        const subastaId = parseInt(document.getElementById("subastaId").value);
        const fechaCierre = new Date(document.getElementById("fechaCierreIso").value);

        const contador = document.getElementById("contadorSubasta");
        const pujaActual = document.getElementById("pujaActual");
        const pujaActualFooter = document.getElementById("pujaActualFooter");
        const usuarioLider = document.getElementById("usuarioLider");
        const cantidadPujas = document.getElementById("cantidadPujas");
        const estadoActual = document.getElementById("estadoActual");
        const estadoBadge = document.getElementById("estadoBadge");
        const tbodyHistorial = document.getElementById("tbodyHistorial");
        const alertaTiempoReal = document.getElementById("alertaTiempoReal");
        const estadoConexion = document.getElementById("estadoConexion");
        const sinPujasBox = document.getElementById("sinPujasBox");
        const tablaHistorialWrapper = document.getElementById("tablaHistorialWrapper");
        const montoInput = document.getElementById("montoOfertado");
        const formPuja = document.getElementById("formPuja");
        const btnRegistrarPuja = document.getElementById("btnRegistrarPuja");
        const mensajePuja = document.getElementById("mensajePuja");
        const contenedorPuja = document.getElementById("contenedorPuja");

        const modalElemento = document.getElementById("modalSubastaFinalizada");
        const modalTituloSubasta = document.getElementById("modalTituloSubasta");
        const modalTextoSubasta = document.getElementById("modalTextoSubasta");
        const modalDetalleGanador = document.getElementById("modalDetalleGanador");
        const modalSubastaFinalizada = modalElemento ? new bootstrap.Modal(modalElemento) : null;
        const contenedorPostCierre = document.getElementById("contenedorPostCierre");
        const urlPagoDetalle = document.getElementById("urlPagoDetalle")?.value;

        function formatearMonto(monto) {
            return "₡" + Number(monto).toLocaleString("es-CR", {
                minimumFractionDigits: 0,
                maximumFractionDigits: 0
            });
        }

        function formatearFecha(fechaTexto) {
            const fecha = new Date(fechaTexto);
            const dd = String(fecha.getDate()).padStart(2, '0');
            const mm = String(fecha.getMonth() + 1).padStart(2, '0');
            const yyyy = fecha.getFullYear();
            const hh = String(fecha.getHours()).padStart(2, '0');
            const mi = String(fecha.getMinutes()).padStart(2, '0');
            const ss = String(fecha.getSeconds()).padStart(2, '0');
            return `${dd}/${mm}/${yyyy} ${hh}:${mi}:${ss}`;
        }

        function aplicarEstadoVisual(estado) {
            estadoActual.textContent = estado;
            estadoBadge.textContent = estado;

            estadoBadge.className = "badge estado-badge";

            const estadoUpper = estado.toUpperCase();

            if (estadoUpper === "ACTIVA") {
                estadoBadge.classList.add("bg-success");
            } else if (estadoUpper === "FINALIZADA") {
                estadoBadge.classList.add("bg-dark");
            } else if (estadoUpper === "PUBLICADA") {
                estadoBadge.classList.add("bg-primary");
            } else if (estadoUpper === "CANCELADA") {
                estadoBadge.classList.add("bg-danger");
            } else {
                estadoBadge.classList.add("bg-secondary");
            }
        }

        function actualizarContador() {
            if (contador.textContent === "Finalizada") return;

            const ahora = new Date();
            const diferencia = fechaCierre - ahora;

            if (diferencia <= 0) {
                contador.textContent = "Finalizada";
                contador.classList.remove("contador-activo");
                contador.classList.add("contador-finalizado");

                aplicarEstadoVisual("FINALIZADA");
                return;
            }

            const horas = Math.floor(diferencia / (1000 * 60 * 60));
            const minutos = Math.floor((diferencia % (1000 * 60 * 60)) / (1000 * 60));
            const segundos = Math.floor((diferencia % (1000 * 60)) / 1000);

            contador.textContent =
                `${String(horas).padStart(2, '0')}:${String(minutos).padStart(2, '0')}:${String(segundos).padStart(2, '0')}`;
        }

        function agregarFilaHistorial(data) {
            sinPujasBox.classList.add("d-none");
            tablaHistorialWrapper.classList.remove("d-none");

            const fila = document.createElement("tr");
            fila.innerHTML = `
                <td>${data.usuario}</td>
                <td>${formatearMonto(data.montoOfertado)}</td>
                <td>${formatearFecha(data.fechaHora)}</td>
            `;

            tbodyHistorial.insertBefore(fila, tbodyHistorial.firstChild);
        }

        function mostrarAlerta(mensaje, tipo = "warning") {
            alertaTiempoReal.innerHTML = `
                <div class="alert alert-${tipo} alert-dismissible fade show" role="alert">
                    ${mensaje}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
        }

        function mostrarMensajePuja(mensaje, tipo = "danger") {
            if (!mensajePuja) return;

            mensajePuja.innerHTML = `
                <div class="alert alert-${tipo} mb-0" role="alert">
                    ${mensaje}
                </div>
            `;
        }

        actualizarContador();
        setInterval(actualizarContador, 1000);

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/subastahub")
            .withAutomaticReconnect()
            .build();

        connection.onreconnecting(() => {
            estadoConexion.innerHTML = `
                <span class="tiempo-real-dot" style="background:#dc3545;"></span>
                Reconectando...
            `;
            estadoConexion.style.background = "#fff5f5";
            estadoConexion.style.color = "#dc3545";
            estadoConexion.style.borderColor = "#f5d0d0";
        });

        connection.onreconnected(() => {
            estadoConexion.innerHTML = `
                <span class="tiempo-real-dot"></span>
                Tiempo real conectado
            `;
            estadoConexion.style.background = "#eefaf2";
            estadoConexion.style.color = "#198754";
            estadoConexion.style.borderColor = "#d8f1e1";
        });

        connection.onclose(() => {
            estadoConexion.innerHTML = `
                <span class="tiempo-real-dot" style="background:#6c757d;"></span>
                Desconectado
            `;
            estadoConexion.style.background = "#f1f3f5";
            estadoConexion.style.color = "#6c757d";
            estadoConexion.style.borderColor = "#dee2e6";
        });

        connection.on("PujaRegistrada", function (data) {
            pujaActual.innerHTML = formatearMonto(data.montoOfertado);

            if (pujaActualFooter) {
                pujaActualFooter.innerHTML = formatearMonto(data.montoOfertado);
            }

            usuarioLider.textContent = data.usuario;
            cantidadPujas.textContent = data.cantidadPujas;
            agregarFilaHistorial(data);
        });

        connection.on("LiderActualizado", function (data) {
            usuarioLider.textContent = data.usuario;
            pujaActual.innerHTML = formatearMonto(data.montoActual);

            if (pujaActualFooter) {
                pujaActualFooter.innerHTML = formatearMonto(data.montoActual);
            }
        });

        connection.on("HistorialActualizado", function (data) {
            agregarFilaHistorial(data);
            cantidadPujas.textContent = data.cantidadPujas;
        });

                         connection.on("SubastaFinalizada", function (data) {
            aplicarEstadoVisual(data.estado || "FINALIZADA");

            contador.textContent = "Finalizada";
            contador.classList.remove("contador-activo");
            contador.classList.add("contador-finalizado");

            if (contenedorPuja) {
                contenedorPuja.classList.add("d-none");
            }

            let mensajeHtml = "";

            if (!data.sinPujas && data.usuarioGanador && data.usuarioGanador.trim() !== "") {
                usuarioLider.textContent = data.usuarioGanador;

                if (data.montoFinal && Number(data.montoFinal) > 0) {
                    pujaActual.innerHTML = formatearMonto(data.montoFinal);

                    if (pujaActualFooter) {
                        pujaActualFooter.innerHTML = formatearMonto(data.montoFinal);
                    }
                }

                mensajeHtml = `
                    <div class="alert alert-success shadow-sm border-0" role="alert">
                        <div class="fw-bold mb-1">🎉 Subasta finalizada</div>
                        <div>Ganador: <strong>${data.usuarioGanador}</strong></div>
                        <div>Monto final: <strong>${formatearMonto(data.montoFinal)}</strong></div>
                    </div>
                `;

                if (modalTituloSubasta) modalTituloSubasta.textContent = "¡Subasta finalizada!";
                if (modalTextoSubasta) modalTextoSubasta.textContent = "Ya no se pueden registrar nuevas pujas.";
                if (modalDetalleGanador) {
                    modalDetalleGanador.innerHTML = `
                        <div class="p-3 rounded-4 bg-light">
                            <div class="fw-bold mb-1">Ganador</div>
                            <div class="fs-5">${data.usuarioGanador}</div>
                            <div class="mt-2 text-muted">Monto final</div>
                            <div class="fs-5 fw-bold text-success">${formatearMonto(data.montoFinal)}</div>
                        </div>
                    `;
                }

        if (contenedorPostCierre && urlPagoDetalle) {
            contenedorPostCierre.innerHTML = `
                <div class="card subasta-card mt-4">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-flag-fill fs-2 text-dark mb-2 d-block"></i>
                        <h5 class="fw-bold mb-2">Resultado final registrado</h5>
                        <p class="text-muted mb-3">
                            La subasta cerró correctamente y ya no admite nuevas pujas.
                        </p>
                        <a href="${urlPagoDetalle}?subastaId=${subastaId}" class="btn btn-success">
                            <i class="bi bi-credit-card me-1"></i> Ver pago
                        </a>
                    </div>
                </div>
            `;
        }

            } else {
                usuarioLider.textContent = "Sin ganador";
                pujaActual.innerHTML = `<span class="text-muted fs-5">Sin pujas</span>`;

                if (pujaActualFooter) {
                    pujaActualFooter.innerHTML = `<span class="text-muted fs-6">Sin pujas</span>`;
                }

                mensajeHtml = `
                    <div class="alert alert-secondary shadow-sm border-0" role="alert">
                        <div class="fw-bold mb-1">Subasta finalizada</div>
                        <div>No se registraron pujas en esta subasta.</div>
                    </div>
                `;

                if (modalTituloSubasta) modalTituloSubasta.textContent = "Subasta finalizada";
                if (modalTextoSubasta) modalTextoSubasta.textContent = "Esta subasta terminó sin recibir ofertas.";
                if (modalDetalleGanador) {
                    modalDetalleGanador.innerHTML = `
                        <div class="p-3 rounded-4 bg-light text-muted">
                            No hubo ganador porque no se registraron pujas.
                        </div>
                    `;
                }

        if (contenedorPostCierre) {
            contenedorPostCierre.innerHTML = `
                <div class="card subasta-card mt-4">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-flag-fill fs-2 text-dark mb-2 d-block"></i>
                        <h5 class="fw-bold mb-2">Subasta finalizada sin pujas</h5>
                        <p class="text-muted mb-0">
                            No se registraron ofertas durante el tiempo de la subasta.
                        </p>
                    </div>
                </div>
            `;
        }
            }

            alertaTiempoReal.innerHTML = mensajeHtml;

            if (modalSubastaFinalizada) {
                modalSubastaFinalizada.show();
            }
        });

                connection.on("SubastaActivada", function (data) {
            aplicarEstadoVisual(data.estado || "ACTIVA");

            if (contenedorPuja) {
                contenedorPuja.classList.remove("d-none");
            }

            mostrarAlerta("La subasta ya está activa y puede recibir pujas.", "success");
        });

        connection.start()
            .then(function () {
                return connection.invoke("UnirseASubasta", subastaId);
            })
            .catch(function (err) {
                console.error(err.toString());
                estadoConexion.innerHTML = `
                    <span class="tiempo-real-dot" style="background:#dc3545;"></span>
                    Error de conexión
                `;
                estadoConexion.style.background = "#fff5f5";
                estadoConexion.style.color = "#dc3545";
                estadoConexion.style.borderColor = "#f5d0d0";
            });

        if (formPuja) {
            formPuja.addEventListener("submit", async function (e) {
                e.preventDefault();

                mensajePuja.innerHTML = "";
                btnRegistrarPuja.disabled = true;

                try {
                    let monto = montoInput.value;

                    monto = monto.replace(",", ".");

                    montoInput.value = parseFloat(monto);

                    const formData = new FormData(formPuja);

                    const response = await fetch('@Url.Action("RegistrarPuja", "Subasta")', {
                        method: 'POST',
                        body: formData,
                        credentials: 'same-origin'
                    });

                    const contentType = response.headers.get("content-type") || "";
                    const rawText = await response.text();

                    let data = null;

                    if (contentType.includes("application/json")) {
                        data = JSON.parse(rawText);
                    } else {
                        console.error("Respuesta no JSON:", rawText);
                        mostrarMensajePuja("El servidor devolvió una respuesta inesperada. Revisá la consola.", "danger");
                        return;
                    }

                    if (!response.ok || !data.ok) {
                        mostrarMensajePuja(data.mensaje || "No se pudo registrar la puja.", "danger");
                        return;
                    }

                    document.getElementById("montoOfertado").value = "";
                    mostrarMensajePuja(data.mensaje, "success");
                }
                catch (error) {
                    console.error("Error al registrar puja:", error);
                    mostrarMensajePuja("Ocurrió un error al registrar la puja.", "danger");
                }
                finally {
                    btnRegistrarPuja.disabled = false;
                }
            });
        }

        window.addEventListener("beforeunload", function () {
            if (connection.state === signalR.HubConnectionState.Connected) {
                connection.invoke("SalirDeSubasta", subastaId);
            }
        });
    </script>
}