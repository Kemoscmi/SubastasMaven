@model IEnumerable<Maven.Application.DTOs.Subasta.PujaHistorialDTO>
@{
    ViewData["Title"] = "Historial de Pujas";
    int subastaId = ViewBag.SubastaId ?? 0;
    var origen = ViewBag.Origen as string;
    bool desdeDetalle = ViewBag.DesdeDetalle ?? false;
}

<h2>Historial de Pujas (Subasta #@subastaId)</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Esta subasta no tiene pujas registradas.
    </div>
}
else
{
    <table class="table table-striped table-bordered align-middle">
        <thead>
            <tr>
                <th>Usuario</th>
                <th>Monto ofertado</th>
                <th>Fecha y hora</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Usuario</td>
                    <td>₡@p.MontoOfertado.ToString("N0")</td>
                    <td>@p.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}

@if (desdeDetalle)
{
    <a class="maven-back"
       asp-action="DetalleVisual"
       asp-route-id="@subastaId"
       asp-route-origen="@origen">
        ← Volver al detalle
    </a>
}
else if (origen == "finalizadas")
{
    <a class="maven-back" asp-action="Finalizadas">
        ← Volver a subastas finalizadas
    </a>
}
else if (origen == "activas")
{
    <a class="maven-back" asp-action="Activas">
        ← Volver a subastas activas
    </a>
}
else if (origen == "borradores")
{
    <a class="maven-back" asp-action="Borradores">
        ← Volver a subastas editables
    </a>
}
else if (origen == "index")
{
    <a class="maven-back" asp-action="Index">
        ← Volver a todas las subastas
    </a>
}
else
{
    <a class="maven-back" asp-action="Index">
        ← Volver a subastas
    </a>
}